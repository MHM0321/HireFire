<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="C:/Users/zee links/HireFire/HireFireBackend/HireFireDB.sqlite" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2297"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="sqlite_sequence" custom_title="0" dock_id="1" table="4,15:mainsqlite_sequence"/><dock_state state="000000ff00000000fd00000001000000020000033b00000224fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000033b0000011800ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE worker (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    password TEXT NOT NULL,
    location TEXT,
    working_days TEXT,  -- e.g., &quot;Mon,Wed,Fri&quot;
    start_time TEXT,    -- e.g., &quot;09:00&quot;
    end_time TEXT,      -- e.g., &quot;17:00&quot;
    bank_account TEXT   -- For earnings withdrawal
);



CREATE TABLE customer (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    password TEXT NOT NULL,
    address TEXT NOT NULL
);



CREATE TABLE appointment (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    worker_id INTEGER NOT NULL,
    customer_id INTEGER NOT NULL,
    date_time TEXT NOT NULL,  -- ISO format: &quot;2025-05-01T14:30&quot;
    status TEXT NOT NULL,      -- &quot;PENDING&quot;, &quot;ACCEPTED&quot;, &quot;REJECTED&quot;
    FOREIGN KEY (worker_id) REFERENCES worker (id),
    FOREIGN KEY (customer_id) REFERENCES customer (id)
);



CREATE TABLE chat (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    worker_id INTEGER NOT NULL,
    customer_id INTEGER NOT NULL,
    message TEXT NOT NULL,
    timestamp TEXT DEFAULT CURRENT_TIMESTAMP,
    sender_type TEXT NOT NULL,  -- &quot;WORKER&quot; or &quot;CUSTOMER&quot;
    FOREIGN KEY (worker_id) REFERENCES worker (id),
    FOREIGN KEY (customer_id) REFERENCES customer (id)
);



CREATE TABLE performance (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    worker_id INTEGER NOT NULL,
    customer_id INTEGER NOT NULL,
    work_date TEXT NOT NULL,  -- &quot;2025-05-01&quot;
    status TEXT NOT NULL,     -- &quot;COMPLETED&quot;, &quot;CANCELLED&quot;
    FOREIGN KEY (worker_id) REFERENCES worker (id),
    FOREIGN KEY (customer_id) REFERENCES customer (id)
);



CREATE TABLE review (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    worker_id INTEGER NOT NULL,
    customer_id INTEGER NOT NULL,
    rating INTEGER NOT NULL,  -- 1-5
    comment TEXT,
    is_from_customer BOOLEAN NOT NULL,  -- TRUE if customer→worker, FALSE if worker→customer
    FOREIGN KEY (worker_id) REFERENCES worker (id),
    FOREIGN KEY (customer_id) REFERENCES customer (id)
);



CREATE TABLE earnings (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    worker_id INTEGER NOT NULL,
    amount REAL NOT NULL,      -- e.g., 150.50
    date_earned TEXT NOT NULL, -- &quot;2025-05-01&quot;
    is_withdrawn BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (worker_id) REFERENCES worker (id)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
